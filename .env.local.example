# Supabase — required to enforce auth on /dashboard.
# Find these in your Supabase project: Settings -> API.
# Copy this file to `.env.local` and fill the values, then create a user under
# Authentication -> Users (or enable sign-ups) so you can log in.
#
# Until these are set, the dashboard is OPEN locally (dev bypass in middleware).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Umami analytics (tracking script only — sends pageviews/events).
# Public values, safe to commit. The script is injected ONLY in production
# builds, so dev visits are never tracked. The website ID is the one from your
# Umami project (Settings -> Websites). NEXT_PUBLIC_UMAMI_SRC is optional and
# defaults to https://cloud.umami.is/script.js.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=f0051c03-05ab-4275-8509-ad928915152f
NEXT_PUBLIC_UMAMI_SRC=https://cloud.umami.is/script.js

# First-party event tracking into the Supabase `events` table (uses the anon
# client above). OFF in dev by default, ON in production builds. To record
# events while testing locally, set this to "true" and restart the dev server.
# NEXT_PUBLIC_TRACK_EVENTS=true

# Dashboard data source. Unset (or anything but "true") -> mock data.
# Set to "true" to read REAL aggregates from the `events` table (requires being
# logged in, since RLS allows only authenticated SELECT). Restart after editing.
# NEXT_PUBLIC_ANALYTICS_LIVE=true
