# Supabase — required to enforce auth on /dashboard.
# Find these in your Supabase project: Settings -> API.
# Copy this file to `.env.local` and fill the values, then create a user under
# Authentication -> Users (or enable sign-ups) so you can log in.
#
# Until these are set, the dashboard is OPEN locally (dev bypass in middleware).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
